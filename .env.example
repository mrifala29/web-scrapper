# Web Scraper Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to git!

# Website Credentials
WEBSITE_MSISDN=your_msisdn_here
WEBSITE_PASSWORD=your_password_here

# Website URLs
BASE_URL=https://your-target-website.com
LOGIN_URL=https://your-target-website.com/login
REPORT_URL=https://your-target-website.com/report

# Scraper Settings
SCRAPE_INTERVAL=86400  # In seconds (86400 = 24 hours)
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=5  # In seconds, with exponential backoff

# Rate Limiting
MIN_REQUEST_DELAY=1  # Minimum seconds between requests
MAX_REQUEST_DELAY=3  # Maximum seconds between requests

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

# Browser Settings
BROWSER_TYPE=chrome  # chrome or firefox
HEADLESS_MODE=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Data Settings
OUTPUT_FORMAT=json  # Options: json, jsonl, clickhouse
DATA_FOLDER=data
KEEP_BACKUPS=10  # Number of backups to keep

# Date Range (Asia/Jakarta timezone)
# Format: YYYY-MM-DD (without time)
START_DATE=2026-01-01
END_DATE=2026-05-05

# Target URLs to scrape (JSON format)
# Add/remove URLs as needed, then edit this list
TARGET_URLS={"paydetail": "/hbshengma/operator/paydetail.html", "deliverydetail": "/hbshengma/operator/deliverydetail.html", "cashdetail": "/hbshengma/operator/cashdetail.html", "essDetail": "/hbshengma/operator/essDetail.html", "mtOrder": "/hbshengma/operator/mtOrder.html", "orderThird": "/hbshengma/operator/orderThird.html", "orderThirdMachine": "/hbshengma/operator/orderThirdMachine.html", "onlineOrderDetail": "/hbshengma/onlineOrderDetail.html"}

# Scheduling
SCHEDULE_TIME=02:00  # Time to run scraper (HH:MM format, 24-hour)
SCHEDULE_TIMEZONE=UTC

# ClickHouse (HTTP port 8123)
CLICKHOUSE_HOST=clickhouse.linkit360.ai
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=hbshengma
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password_here
CLICKHOUSE_SECURE=false
